# ─── EverydayAI Environment Variables ────────────────────────────
#
# PRODUCTION DATABASE (Supabase Transaction Pooler)
# Use this for the running app — handles thousands of connections
# Port 6543 = Transaction mode = Supavisor pooler
# Get from: supabase.com/dashboard → Connect → Transaction pooler
DATABASE_URL=postgresql://postgres.stgrsijraeswmxiyinzz:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# MIGRATIONS DATABASE (Supabase Direct Connection)
# Use this for drizzle migrations ONLY — not for the running app
# Port 5432 = Direct connection = bypasses pooler
# Get from: supabase.com/dashboard → Connect → Direct connection
DATABASE_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.stgrsijraeswmxiyinzz.supabase.co:5432/postgres

# SESSION SECRET
# Must be at least 32 characters — generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_minimum_32_characters

# NODE ENVIRONMENT
NODE_ENV=development

# SUPABASE CLIENT (Frontend)
# Get from: supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://stgrsijraeswmxiyinzz.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# SERVER PORT
PORT=3000

# REDIS (for BullMQ job queues)
# Local dev: redis://localhost:6379
# Railway: set automatically when Redis service is added
REDIS_URL=redis://localhost:6379

# LOGGING
LOG_LEVEL=info

# OPTIONAL: Extra domains for CSP connect-src
# CSP_CONNECT_SRC=https://api.example.com,https://hooks.example.com
