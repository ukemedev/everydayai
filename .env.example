DATABASE_URL=your_supabase_connection_string_here
SESSION_SECRET=your_session_secret_here
NODE_ENV=development

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Optional CSP allowlist ─────────────────────────────────────────────────
# Extra domains the frontend is allowed to connect to (CSP connect-src). Comma-separated.
# The backend automatically includes the Supabase URL from VITE_SUPABASE_URL.
# CSP_CONNECT_SRC=https://api.example.com,https://hooks.example.com
