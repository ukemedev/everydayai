# ─────────────────────────────────────────────────────────────────────────────
# Railway Environment Variables
#
# Set ALL of these in your Railway project dashboard:
#   Railway → Your Project → Variables tab
#
# NEVER paste these into the Dockerfile or commit them to GitHub.
# Secrets baked into a Docker image are exposed to anyone who pulls the image.
# Railway injects these into the container at runtime — that's the safe way.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Your Supabase project URL (from Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anonymous key — safe to expose in frontend code
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase service role key — secret, server-side only, bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Supabase Postgres connection string (from Supabase → Project Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Random secret used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=your-random-64-char-hex-string

# Must be "production" on Railway so the server skips dev-only behaviour
NODE_ENV=production

# ── CORS — Required for Railway ───────────────────────────────────────────────
# After deploying, Railway gives your app a URL like:
#   https://everydayai-production.up.railway.app
# Paste that URL here (no trailing slash) so the API accepts requests from it.
# If you add a custom domain later, add it here too (comma-separated).
ALLOWED_ORIGINS=https://your-app-name.up.railway.app

# ── Optional ─────────────────────────────────────────────────────────────────

# Extra domains the browser is allowed to connect to (for Content Security Policy)
# CSP_CONNECT_SRC=https://api.example.com

# Override API port if needed — Railway sets PORT automatically, leave this unset
# API_PORT=8080
